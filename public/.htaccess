# ============================================================
# Security
# ============================================================

# Site URL (change this when switching domains)
SetEnv SITE_URL https://scoutsvremde.kobecloud.be

# Disable directory listing
Options -Indexes +Includes

# Enable SSI for HTML files
AddOutputFilter INCLUDES .html

# Disable TRACE method
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_METHOD} ^TRACE
    RewriteRule .* - [F]
</IfModule>

# Clean URLs: /pages/foo.html → /foo
<IfModule mod_rewrite.c>
    # Redirect /pages/foo.html → /foo (301 permanent)
    RewriteCond %{THE_REQUEST} \s/pages/([^.]+)\.html[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L]

    # Internally rewrite /foo → /pages/foo.html (if the file exists)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{DOCUMENT_ROOT}/pages/%{REQUEST_URI}.html -f
    RewriteRule ^(.+)$ /pages/$1.html [L]
</IfModule>

# Hide Apache version info
ServerSignature Off

# Note: HTTPS redirect is handled by the reverse proxy, not here

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), camera=(), microphone=()"
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-eval' https://cdn.tailwindcss.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://*.tile.openstreetmap.org https://*.google.com https://*.googleapis.com https://*.gstatic.com; frame-src 'self' https://www.google.com https://maps.google.com; object-src 'none'; base-uri 'self';"
</IfModule>

# Block access to hidden files and directories (except .well-known for Let's Encrypt)
<IfModule mod_rewrite.c>
    RewriteCond %{REQUEST_URI} "!(^|/)\.well-known/([^./]+./)+" [NC]
    RewriteCond %{SCRIPT_FILENAME} -d [OR]
    RewriteCond %{SCRIPT_FILENAME} -f
    RewriteRule "(^|/)\." - [F]
</IfModule>

# ============================================================
# Performance
# ============================================================

# Enable compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml application/xml text/xml
    AddOutputFilterByType DEFLATE application/font-woff application/font-woff2
</IfModule>

# Enable browser caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 day"
    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType image/jpeg "access plus 1 week"
    ExpiresByType image/png "access plus 1 week"
    ExpiresByType image/webp "access plus 1 week"
    ExpiresByType image/svg+xml "access plus 1 week"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType application/pdf "access plus 1 week"
    ExpiresByType application/font-woff "access plus 1 week"
    ExpiresByType application/font-woff2 "access plus 1 week"
</IfModule>

# KeepAlive
<IfModule mod_headers.c>
    Header set Connection keep-alive
</IfModule>

# ============================================================
# MIME types
# ============================================================
<IfModule mod_mime.c>
    # Web fonts
    AddType font/woff2 .woff2
    AddType font/woff .woff
    AddType font/ttf .ttf
    AddType font/otf .otf

    # Images
    AddType image/webp .webp
    AddType image/svg+xml .svg .svgz
    AddType image/x-icon .ico

    # Media
    AddType video/mp4 .mp4
    AddType video/webm .webm

    # Data
    AddType application/json .json
    AddType application/manifest+json .webmanifest
    AddType text/xml .xml
</IfModule>

# ============================================================
# Custom error pages
# ============================================================
ErrorDocument 400 /errors/500.html
ErrorDocument 401 /errors/403.html
ErrorDocument 403 /errors/403.html
ErrorDocument 404 /errors/404.html
ErrorDocument 405 /errors/403.html
ErrorDocument 500 /errors/500.html
ErrorDocument 502 /errors/500.html
ErrorDocument 503 /errors/500.html
